{
  "name": "enterprise-rag-assistant",
  "version": "1.0.0",
  "description": "Production-ready Technical Support Copilot using RAG",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && NODE_ENV=development nodemon index.js",
    "server:start": "cd server && NODE_ENV=production node index.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "db:migrate": "cd server && node scripts/migrate.js",
    "db:seed": "cd server && node scripts/seed.js",
    "lint": "eslint .",
    "test": "jest"
  },
  "keywords": ["RAG", "Enterprise", "AI", "Support"],
  "author": "RAG Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.48.0",
    "jest": "^29.7.0"
  }
}
